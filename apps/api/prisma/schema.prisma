datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String
  twoFactorSecret String?
  positions       Position[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Asset {
  id                String             @id @default(uuid())
  ticker            String             @unique
  isin              String             @unique
  name              String
  currentPrice      Float
  currency          String             
  description       String?
  return1d          Float?
  return1w          Float?
  return1m          Float?
  return3m          Float?
  returnYtd         Float?
  return6m          Float?
  return1y          Float?
  return3y          Float?
  return5y          Float?
  roe               Float?
  operatingMargin   Float?
  debtToAsset       Float?
  unitPrice         Float              @default(1.0)
  industry          String             @default("Technology")
  regions           String[]
  allocations       AssetAllocation[]
  regionalExposures RegionalExposure[]
  positions         Position[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model AssetAllocation {
  id             String   @id @default(uuid())
  assetId        String
  asset          Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  instrumentType String   
  percentage     Float    
}

model RegionalExposure {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  region     String   
  percentage Float    
}

model Position {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id])
  quantity   Float
  avgPrice   Float    
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}